# Copy this file to .env for local secrets. Do not commit the real .env file.

# NVIDIA NIM / build.nvidia.com
NVIDIA_API_KEY=
# Also supported because NVIDIA docs often use this name:
NGC_API_KEY=

# Optional cloud providers
OPENAI_API_KEY=
GEMINI_API_KEY=
CUSTOM_API_KEY=

# Optional higher Semantic Scholar quota for Phase 1 paper search
SEMANTIC_SCHOLAR_API_KEY=
